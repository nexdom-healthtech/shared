{
  "name": "@nexdom/shared",
  "version": "0.0.0",
  "description": "Some models, services and utils we need on daily bases.",
  "keywords": [
    "lib",
    "nexdom",
    "typescript",
    "utils"
  ],
  "homepage": "https://nexdom-healthtech.github.io/shared/",
  "bugs": {
    "url": "https://github.com/nexdom-healthtech/shared/issues"
  },
  "license": "MIT",
  "author": "Rafael Perini <rafael.perini@nexdom.tec.br>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nexdom-healthtech/shared.git",
    "home": "https://github.com/nexdom-healthtech/shared#readme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./models": "./dist/models.mjs",
    "./utils": "./dist/utils.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vpr build",
    "prepare": "vp config",
    "depcruise": "depcruise src --output-type err-long",
    "depcruise:graph": "depcruise src --output-type dot| dot -T svg > dependencygraph.svg",
    "depcruise:graph:no-tests": "depcruise src --exclude \"__tests__\"  --output-type dot | dot -T svg > dependencygraph.no-tests.svg",
    "docs:dev": "vitepress dev docs --host",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "4.1.9",
    "bumpp": "^11.1.0",
    "dependency-cruiser": "^18.0.0",
    "jsdom": "^29.1.1",
    "oxc-minify": "^0.140.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.3",
    "vitepress": "2.0.0-alpha.17",
    "vue": "^3.5.39"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "pnpm@10.32.0"
}
